// MuSig2 + BIP-375 Silent Payments — GUI
// 3-of-3 MuSig2 signing workflow visualization

import { Button, VerticalBox, HorizontalBox, ScrollView, ComboBox } from "std-widgets.slint";

export struct PsbtField {
    field-name: string,
    key-type: string,
    key-preview: string,
    value-preview: string,
    is-highlighted: bool,
    map-index: int,
}

export struct TransactionSummary {
    total-input: int,
    total-output: int,
    fee: int,
    num-inputs: int,
    num-outputs: int,
}

export struct PhaseProgress {
    ecdh-done: int,
    nonce-done: int,
    signed-done: int,
}

component MenuButton inherits Button {
    preferred-height: 40px;
    max-height: 40px;
}

component PSBTFields inherits HorizontalBox {
    padding: 8px;
    spacing: 8px;

    in property <PsbtField> field;

    Text {
        text: field.key-type;
        font-size: 12px;
        color: #666666;
        vertical-alignment: center;
        max-width: 40px;
    }

    if field.map-index >= 0: Text {
        text: "[" + field.map-index + "]";
        font-size: 12px;
        color: #888888;
        font-weight: 700;
        vertical-alignment: center;
        horizontal-alignment: left;
        max-width: 30px;
    }

    TextInput {
        text: field.field-name;
        font-size: 14px;
        color: #2c2c2c;
        read-only: true;
        horizontal-alignment: left;
        max-width: 300px;
    }

    VerticalBox {
        alignment: LayoutAlignment.center;
        spacing: 2px;
        padding: 0px;
        horizontal-stretch: 1;

        if field.key-preview != "": TextInput {
            read-only: true;
            text: "key: " + field.key-preview;
            font-size: 10px;
            color: #666666;
            horizontal-alignment: right;
        }

        TextInput {
            read-only: true;
            text: field.value-preview;
            font-size: 12px;
            color: #666666;
            horizontal-alignment: right;
        }
    }
}

export component AppWindow inherits Window {
    title: "BIP-375 MuSig2-Signer Demo";
    preferred-width: 1400px;
    preferred-height: 900px;
    min-width: 1200px;
    min-height: 700px;

    // Workflow state string (matches WorkflowState::as_str())
    in-out property <string> workflow-state: "Init";

    // Party selector
    in-out property <bool> has-pending-parties: false;
    in-out property <string> selected-party: "";
    in-out property <[string]> available-parties;

    // PSBT fields
    in-out property <bool> has-psbt: false;
    in-out property <[PsbtField]> global-fields: [];
    in-out property <[PsbtField]> input-fields: [];
    in-out property <[PsbtField]> output-fields: [];

    // Transaction summary
    in-out property <TransactionSummary> tx-summary: {
        total-input: 0, total-output: 0, fee: 0, num-inputs: 0, num-outputs: 0,
    };

    // Phase progress counters
    in-out property <PhaseProgress> phase-progress: {
        ecdh-done: 0, nonce-done: 0, signed-done: 0,
    };

    // Aggregated schnorr sig hex (shown after extraction)
    in-out property <string> schnorr-sig: "";

    // Callbacks
    callback create-psbt();
    callback add-ecdh(string);
    callback add-nonce(string);
    callback partial-sign(string);
    callback extract();
    callback export-psbt();
    callback reset();

    // Derived state helpers
    pure function is-ecdh-phase() -> bool {
        workflow-state == "EcdhInProgress(0)" ||
        workflow-state == "EcdhInProgress(1)" ||
        workflow-state == "EcdhInProgress(2)"
    }
    pure function is-nonce-phase() -> bool {
        workflow-state == "OutputDerived" ||
        workflow-state == "NonceInProgress(1)" ||
        workflow-state == "NonceInProgress(2)"
    }
    pure function is-signing-phase() -> bool {
        workflow-state == "NonceComplete" ||
        workflow-state == "SigningInProgress(1)" ||
        workflow-state == "SigningInProgress(2)"
    }

    VerticalBox {
        // Header
        Rectangle {
            background: #444444;
            height: 60px;

            HorizontalBox {
                padding: 16px;

                Text {
                    text: "BIP-375 MuSig2-Signer Demo";
                    font-size: 20px;
                    font-weight: 700;
                    horizontal-alignment: left;
                }

                Rectangle { horizontal-stretch: 1; }

                Text {
                    text:
                        workflow-state == "Init" ? "⚪ Ready" :
                        workflow-state == "EcdhInProgress(0)" ? "🔵 ECDH (0/3)" :
                        workflow-state == "EcdhInProgress(1)" ? "🔵 ECDH (1/3)" :
                        workflow-state == "EcdhInProgress(2)" ? "🟡 ECDH (2/3)" :
                        workflow-state == "OutputDerived" ? "🟢 SP Output Computed" :
                        workflow-state == "NonceInProgress(1)" ? "🔵 Nonce (1/3)" :
                        workflow-state == "NonceInProgress(2)" ? "🟡 Nonce (2/3)" :
                        workflow-state == "NonceComplete" ? "🟢 Nonces Ready" :
                        workflow-state == "SigningInProgress(1)" ? "🔵 Signed (1/3)" :
                        workflow-state == "SigningInProgress(2)" ? "🟡 Signed (2/3)" :
                        workflow-state == "PartialSigningComplete" ? "🟢 Partial Signing Complete" :
                        workflow-state == "Extracted" ? "✅ Signed + Extracted" :
                        "⚪ Ready";
                    font-size: 16px;
                    font-weight: 700;
                }
            }
        }

        HorizontalBox {
            vertical-stretch: 1;
            padding: 0px;

            // Left panel
            Rectangle {
                width: 350px;
                background: #444444;

                VerticalBox {
                    alignment: LayoutAlignment.end;
                    padding: 16px;
                    spacing: 16px;

                    Text {
                        text: "Workflow Steps";
                        font-size: 24px;
                        font-weight: 700;
                    }

                    // Current state indicator
                    VerticalBox {
                        spacing: 8px;

                        Text {
                            text: "Current State:";
                            font-size: 16px;
                        }

                        Text {
                            text:
                                workflow-state == "Init" ? "● Ready" :
                                workflow-state == "EcdhInProgress(0)" ? "● ECDH (0/3)" :
                                workflow-state == "EcdhInProgress(1)" ? "● ECDH (1/3)" :
                                workflow-state == "EcdhInProgress(2)" ? "● ECDH (2/3)" :
                                workflow-state == "OutputDerived" ? "● Output Derived" :
                                workflow-state == "NonceInProgress(1)" ? "● Nonce (1/3)" :
                                workflow-state == "NonceInProgress(2)" ? "● Nonce (2/3)" :
                                workflow-state == "NonceComplete" ? "● Nonces Ready" :
                                workflow-state == "SigningInProgress(1)" ? "● Signed (1/3)" :
                                workflow-state == "SigningInProgress(2)" ? "● Signed (2/3)" :
                                workflow-state == "PartialSigningComplete" ? "● Partial Signing Complete" :
                                workflow-state == "Extracted" ? "● Extracted" :
                                "● Ready";
                            color:
                                workflow-state == "Init" ? #808080 :
                                (workflow-state == "EcdhInProgress(0)" || workflow-state == "EcdhInProgress(1)") ? #3399e6 :
                                workflow-state == "EcdhInProgress(2)" ? #e6b300 :
                                workflow-state == "OutputDerived" ? #33cc33 :
                                workflow-state == "NonceInProgress(1)" ? #3399e6 :
                                workflow-state == "NonceInProgress(2)" ? #e6b300 :
                                workflow-state == "NonceComplete" ? #33cc33 :
                                workflow-state == "SigningInProgress(1)" ? #3399e6 :
                                workflow-state == "SigningInProgress(2)" ? #e6b300 :
                                workflow-state == "PartialSigningComplete" ? #9966e6 :
                                workflow-state == "Extracted" ? #33cc33 :
                                #808080;
                            font-size: 14px;
                        }
                    }

                    Rectangle { height: 1px; background: #666666; }

                    // Step buttons
                    VerticalBox {
                        spacing: 8px;
                        padding: 0px;

                        MenuButton {
                            text: "1. Create PSBT\n(Key Setup + MuSig2 Input)";
                            enabled: workflow-state == "Init" || workflow-state == "Extracted";
                            clicked => { root.create-psbt(); }
                        }

                        // Party selector (shown during per-party phases)
                        if has-pending-parties: HorizontalBox {
                            spacing: 8px;
                            alignment: LayoutAlignment.start;

                            Text {
                                text: "Select Party:";
                                vertical-alignment: center;
                                font-size: 14px;
                            }

                            ComboBox {
                                model: available-parties;
                                current-value <=> selected-party;
                            }
                        }

                        MenuButton {
                            text: "2. Add ECDH Share\n(Partial sk_i·scan_key + DLEQ)";
                            enabled: selected-party != "" && has-pending-parties && root.is-ecdh-phase();
                            clicked => { root.add-ecdh(selected-party); }
                        }

                        MenuButton {
                            text: "3. Add Nonce\n(BIP-373 PSBT_IN_MUSIG2_PUB_NONCE)";
                            enabled: selected-party != "" && has-pending-parties && root.is-nonce-phase();
                            clicked => { root.add-nonce(selected-party); }
                        }

                        MenuButton {
                            text: "4. Partial Sign\n(BIP-373 PSBT_IN_MUSIG2_PARTIAL_SIG)";
                            enabled: selected-party != "" && has-pending-parties && root.is-signing-phase();
                            clicked => { root.partial-sign(selected-party); }
                        }

                        MenuButton {
                            text: "5. Aggregate & Extract\n(Schnorr sig + Transaction)";
                            enabled: workflow-state == "PartialSigningComplete";
                            clicked => { root.extract(); }
                        }
                    }

                    Rectangle { height: 1px; background: #666666; }

                    MenuButton {
                        text: "💾 Export PSBT";
                        enabled: has-psbt;
                        clicked => { root.export-psbt(); }
                    }

                    Rectangle { height: 1px; background: #666666; }

                    MenuButton {
                        text: "🔄 Reset";
                        clicked => { root.reset(); }
                    }
                }
            }

            // Center panel — PSBT viewer
            Rectangle {
                background: #444444;
                horizontal-stretch: 1;

                if !has-psbt: VerticalBox {
                    alignment: center;

                    Text {
                        text: "No PSBT Created Yet";
                        font-size: 20px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Start workflow by clicking \"1. Create PSBT\"";
                        color: #808080;
                        horizontal-alignment: center;
                    }
                }

                if has-psbt: VerticalBox {
                    padding: 16px;

                    Text {
                        text: "PSBT Properties";
                        font-size: 24px;
                        font-weight: 700;
                    }

                    ScrollView {
                        VerticalBox {
                            spacing: 16px;

                            if global-fields.length > 0: VerticalBox {
                                spacing: 8px;

                                Rectangle {
                                    background: #555555;
                                    height: 32px;
                                    Text {
                                        text: "Global Fields (" + global-fields.length + " fields)";
                                        font-size: 18px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        color: #ffffff;
                                    }
                                }

                                for field in global-fields: Rectangle {
                                    height: 40px;
                                    background: field.is-highlighted ? #ccffcc : #f7f7f7;
                                    PSBTFields { field: field; }
                                }
                            }

                            if input-fields.length > 0: VerticalBox {
                                spacing: 8px;

                                Rectangle {
                                    background: #555555;
                                    height: 32px;
                                    Text {
                                        text: "Input Maps";
                                        font-size: 18px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        color: #ffffff;
                                    }
                                }

                                for field in input-fields: Rectangle {
                                    height: 40px;
                                    background: field.is-highlighted ? #ccffcc : #f7f7f7;
                                    PSBTFields { field: field; }
                                }
                            }

                            if output-fields.length > 0: VerticalBox {
                                spacing: 8px;

                                Rectangle {
                                    background: #555555;
                                    height: 32px;
                                    Text {
                                        text: "Output Maps";
                                        font-size: 18px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        color: #ffffff;
                                    }
                                }

                                for field in output-fields: Rectangle {
                                    height: 40px;
                                    background: field.is-highlighted ? #ccffcc : #f7f7f7;
                                    PSBTFields { field: field; }
                                }
                            }
                        }
                    }
                }
            }
        }

        // Bottom panel
        Rectangle {
            background: #484848;
            height: 100px;

            VerticalBox {
                padding: 10px;

                if has-psbt: HorizontalBox {
                    spacing: 10px;
                    padding: 5px;

                    Text { text: "Transaction Summary"; font-weight: 700; }
                    Rectangle { width: 1px; height: 100%; background: #666666; }
                    Text { text: "Inputs: " + tx-summary.total-input + " sats (" + tx-summary.num-inputs + " items)"; }
                    Rectangle { width: 1px; height: 100%; background: #666666; }
                    Text { text: "Outputs: " + tx-summary.total-output + " sats (" + tx-summary.num-outputs + " items)"; }
                    Rectangle { width: 1px; height: 100%; background: #666666; }
                    Text {
                        text: "Fee: " + tx-summary.fee + " sats";
                        color: tx-summary.fee > 100000 ? #e6b300 : #33cc33;
                    }
                }

                if has-psbt: Rectangle { width: 100%; height: 1px; background: #666666; }

                if has-psbt: HorizontalBox {
                    spacing: 20px;

                    Text {
                        text: "ECDH " + phase-progress.ecdh-done + "/3";
                        color: phase-progress.ecdh-done >= 3 ? #33cc33 : #e6b300;
                        font-size: 12px;
                        font-weight: 700;
                    }

                    Text {
                        text: "Nonce " + phase-progress.nonce-done + "/3";
                        color: phase-progress.nonce-done >= 3 ? #33cc33 :
                               phase-progress.nonce-done > 0 ? #e6b300 : #808080;
                        font-size: 12px;
                        font-weight: 700;
                    }

                    Text {
                        text: "Sig " + phase-progress.signed-done + "/3";
                        color: phase-progress.signed-done >= 3 ? #33cc33 :
                               phase-progress.signed-done > 0 ? #e6b300 : #808080;
                        font-size: 12px;
                        font-weight: 700;
                    }

                    if schnorr-sig != "": Text {
                        text: "Schnorr: " + schnorr-sig;
                        font-size: 10px;
                        color: #33cc33;
                        overflow: elide;
                    }
                }

                if !has-psbt: Text {
                    text: "No transaction data";
                    color: #808080;
                }
            }
        }
    }
}
